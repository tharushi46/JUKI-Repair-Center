rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Publicly readable product images
    match /products/{allPaths=**} {
      allow read: if true;

      // Admin write access (email/password auth)
      allow write: if request.auth != null
        && request.auth.token.email == "jukirepaircenter@gmail.com";
    }
  }
}

